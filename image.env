# ─── EDIT THIS FILE — per-fork live config ─────────────────────────
# Sourced by every script via scripts/lib/load-image-env.sh.
# Precedence: shell / CI vars > this file. Keep SECRETS OUT — pass
# tokens/passwords via masked CI variables on the project.
#
# cert-builder produces a pre-baked alpine image trusted with the
# corp CA + airgap-safe apk repos. Downstream consumers point at it
# via CERT_BUILDER_IMAGE in their image.env.
# ───────────────────────────────────────────────────────────────────

# ── Upstream ────────────────────────────────────────────────────────
UPSTREAM_REGISTRY="artifactory.example.com/dockerhub/library"
UPSTREAM_IMAGE="alpine"
# renovate: datasource=docker depName=library/alpine
UPSTREAM_TAG="3.20"

# IMAGE_NAME defaults to the leaf of UPSTREAM_IMAGE ("alpine"), which
# is too generic for this artifact — override to "cert-builder" so
# the pushed image clearly identifies its purpose.
IMAGE_NAME="cert-builder"

# Cert sidecar base — the template's standard alpine. Same family as
# our final image; sidecar build is essentially a no-op stage that
# just produces a trust-store fragment for the FROM base COPY.
CERT_BUILDER_IMAGE="artifactory.example.com/dockerhub/library/alpine:3.20"

VENDOR="example.com"

# ── Push backend ────────────────────────────────────────────────────
REGISTRY_KIND="artifactory"

# ── Artifactory backend ─────────────────────────────────────────────
ARTIFACTORY_PRO="false"
ARTIFACTORY_URL="https://artifactory.example.com"
ARTIFACTORY_USER="svc-cicd"
ARTIFACTORY_TEAM="platform"
ARTIFACTORY_ENVIRONMENT="dev"
ARTIFACTORY_PUSH_HOST="docker.artifactory.example.com"

# Push layout (matches prometheus / redis):
#   Docker push:   docker.artifactory.example.com/cert-builder:<tag>
#   REST manifest: team-docker-dev-local/cert-builder/<tag>/manifest.json
ARTIFACTORY_IMAGE_REF='${ARTIFACTORY_PUSH_HOST}/${IMAGE_NAME}:${IMAGE_TAG}'
ARTIFACTORY_MANIFEST_PATH='team-docker-dev-local/${IMAGE_NAME}/${IMAGE_TAG}/manifest.json'

# ── Tool install mirrors (air-gap) ──────────────────────────────────
CRANE_URL="https://artifactory.example.com/artifactory/team-generic-dev/go-containerregistry/releases/download/v0.20.2/go-containerregistry_Linux_x86_64.tar.gz"
JF_BINARY_URL="https://artifactory.example.com/artifactory/team-generic-dev/jfrog-cli/v2-jf/2.103.0/jfrog-cli-linux-amd64/jf"

# ── Custom fork extension (bake-apk-mirror.sh reads this) ──────────
# Bakes /etc/apk/repositories into the cert-builder image so the
# downstream consumers using this image as CERT_BUILDER_IMAGE get the
# airgap-safe apk source automatically. Empty = no rewrite.
APK_MIRROR="https://artifactory.example.com/artifactory/alpine"

# ── Secrets (CI variables only — never here) ────────────────────────
#   ARTIFACTORY_PASSWORD       (or ARTIFACTORY_TOKEN)
#   SPLUNK_HEC_TOKEN           (ingest stage Splunk sink)
#   CORP_CA_URL                (artifactory URL of the PEM to bake;
#                               .gitlab-ci.yml's pre-build curls it
#                               into certs/ and removes after build)
